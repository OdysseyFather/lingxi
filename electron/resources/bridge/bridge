#!/bin/bash
# 灵犀本地路由层包装脚本：用打包内 Node 运行 bridge-server.mjs
DIR="$(cd "$(dirname "$0")" && pwd)"
NODE_BIN="$DIR/../node-bin/node"
SERVER="$DIR/bridge-server.mjs"
if [ ! -x "$NODE_BIN" ]; then
  # dev fallback：使用 PATH 上的 node
  NODE_BIN="$(command -v node)"
fi
if [ -z "$NODE_BIN" ]; then
  echo "[bridge] no node binary found" >&2
  exit 1
fi
exec "$NODE_BIN" "$SERVER" "$@"
